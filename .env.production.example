# Database Configuration for Production
# On Render, these values are automatically injected
# If not auto-injected, manually set them in Render Dashboard:
# Service → Environment → Add Variable

# Option 1: Use DATABASE_URL (Render's standard format)
# DATABASE_URL=mysql://username:password@hostname:port/databasename

# Option 2: Use individual variables
# DB_HOST=your-database-host.render.com
# DB_PORT=3306
# DB_USER=admin
# DB_PASSWORD=your-secure-password
# DB_NAME=trainees_accounting_system

# Session configuration
# SESSION_SECRET is auto-generated by Render

# Node environment
NODE_ENV=production
